# ======================================================
# 🌐 Core Server
# ======================================================
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# ======================================================
# 🔐 JWT (REQUIRED IN PRODUCTION)
# ======================================================
JWT_ACCESS_SECRET=replace_with_strong_random_string
JWT_REFRESH_SECRET=replace_with_strong_random_string
COOKIE_SECURE=false

# ======================================================
# 📧 EMAIL CONFIGURATION
# ======================================================
# Options:
# disabled  -> logs emails only (safe dev mode)
# gmail     -> uses Gmail SMTP
EMAIL_PROVIDER=disabled

# Sender identity
EMAIL_FROM_EMAIL=no-reply@yourschool.com
EMAIL_FROM_NAME=StudisNest powered by StudisTalk

# Only required if EMAIL_PROVIDER=gmail
GMAIL_SMTP_USER=your_email@gmail.com
GMAIL_SMTP_PASS=your_gmail_app_password


# ======================================================
# 🌍 GOOGLE TRANSLATE
# ======================================================
TRANSLATION_PROVIDER=google
TRANSLATION_FALLBACK=local

GOOGLE_TRANSLATE_KEYFILE=server/secrets/gcp-translate-key.json
# or
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/key.json


# ======================================================
# 📱 TWILIO (Optional)
# ======================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ======================================================
# 🎞 Media Conversion (ffmpeg)
# ======================================================
# auto   -> prefer ffmpeg-static if installed; fallback to system ffmpeg
# system -> force using system-installed ffmpeg
# static -> force using ffmpeg-static (error if not available)
FFMPEG_MODE=auto

# Optional: override exact ffmpeg path
# FFMPEG_PATH=/usr/bin/ffmpeg

# If true: conversion failures abort uploads.
# If false: conversion errors are logged but uploads still succeed.
FFMPEG_STRICT=false

# ======================================================
# 💾 Persistent Storage (SQLite + Uploads)
# ======================================================
# Default (dev): uses files inside the repo
DB_PATH=worknest.db
UPLOADS_DIR=uploads

# Production recommended example (VPS):
# DB_PATH=/var/lib/worknest/worknest.db
# UPLOADS_DIR=/var/lib/worknest/uploads

# ======================================================
# 🤖 AI / OpenAI Realtime (optional)
# ======================================================
# OAuth-style Realtime sessions expect the server to mint ephemeral tokens,
# so keep your API key secret in this backend.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-mini
OPENAI_REALTIME_URL=https://api.openai.com/v1/realtime/sessions
OPENAI_REALTIME_VOICE=alloy
# Optional: per-token billing rates for cost calculations (plain numbers per token)
OPENAI_BILLING_EUR_PER_INPUT_TOKEN=0.000015
OPENAI_BILLING_EUR_PER_OUTPUT_TOKEN=0.00002
AI_IDLE_TIMEOUT_SECONDS=45
AI_CLEANUP_SWEEP_SECONDS=30
AI_IDLE_TIMEOUT_SECONDS=45
AI_CLEANUP_SWEEP_SECONDS=30
# Optional: time-based rate for session logging (EUR per second)
AI_TIME_RATE_EUR_PER_SECOND=0.000166
